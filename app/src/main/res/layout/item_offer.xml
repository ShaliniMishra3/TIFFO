<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginTop="12dp"
    app:cardCornerRadius="24dp"
    app:cardElevation="2dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="18dp"
        android:background="#F4E3C9"> <!-- soft food tone -->

        <!-- Light circle background (design element) -->
        <View
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:layout_alignParentEnd="true"
            android:layout_marginEnd="-40dp"
            android:layout_marginTop="-40dp"
            android:alpha="0.08"
            android:background="@drawable/ic_circle_accent"/>

        <!-- TEXT CONTENT -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_centerVertical="true">

            <!-- Tag -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TODAY’S MENU"
                android:textSize="10sp"
                android:textStyle="bold"
                android:textColor="#BF360C"
                android:background="@drawable/bg_tag_glass"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:letterSpacing="0.1"/>

            <!-- Main Menu -->
            <TextView
                android:id="@+id/txtMenuItems"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Dal • 2 Roti • Rice "
                android:textColor="#3E2723"
                android:textSize="18sp"
                android:textStyle="bold"/>

            <!-- Sub text -->
            <TextView
                android:id="@+id/txtMenuDesc"
                android:layout_width="180dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Freshly cooked • Ready by 1 PM"
                android:textColor="#6D4C41"
                android:textSize="12sp"/>

            <!-- Button -->
            <com.google.android.material.button.MaterialButton
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginTop="12dp"
                android:text="View Menu"
                android:textAllCaps="false"
                android:textSize="12sp"
                android:textStyle="bold"
                app:cornerRadius="12dp"
                app:backgroundTint="#F41444"/>
        </LinearLayout>

        <!-- FOOD IMAGE -->
        <com.google.android.material.imageview.ShapeableImageView
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:scaleType="centerCrop"
            android:src="@drawable/i2"
            android:layout_marginStart="10dp"
            app:shapeAppearanceOverlay="@style/CircleImage"
            app:strokeWidth="3dp"
            app:strokeColor="#FFFFFF"/>
    </RelativeLayout>

</com.google.android.material.card.MaterialCardView>
