<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="5dp"
    android:layout_marginVertical="10dp"
    app:cardCornerRadius="28dp"
    app:cardElevation="0dp"
    app:strokeWidth="0dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_offer_gradient"
        android:padding="20dp">
        <View
            android:layout_width="150dp"
            android:layout_height="150dp"
            android:layout_alignParentEnd="true"
            android:layout_marginEnd="-50dp"
            android:layout_marginTop="-50dp"
            android:alpha="0.1"
            android:background="@drawable/ic_circle_accent" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:orientation="vertical">

            <TextView
                android:id="@+id/txtOfferTag"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_tag_glass"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:text="LIMITED OFFER"
                android:textColor="#E65100"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"/>

            <TextView
                android:id="@+id/txtOfferValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="20% OFF"
                android:textColor="#EB0C4A"
                android:textSize="28sp"
                android:fontFamily="sans-serif-black" />

            <TextView
                android:layout_width="160dp"
                android:layout_height="wrap_content"
                android:text="On your first home-cooked tiffin order"
                android:textColor="#C11948"
                android:textSize="12sp"
                android:lineSpacingExtra="2dp"
                android:fontFamily="sans-serif-medium"/>

            <com.google.android.material.button.MaterialButton
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:layout_marginTop="12dp"
                android:text="Order Now"
                android:textAllCaps="false"
                android:textSize="12sp"
                android:textStyle="bold"
                app:cornerRadius="12dp"
                app:backgroundTint="#FA2359"
                app:elevation="4dp"/>
        </LinearLayout>
        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/imgOffer"
            android:layout_width="150dp"
            android:layout_height="150dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:layout_marginEnd="0dp"  android:padding="2dp"
            android:src="@drawable/i2"
            android:scaleType="centerCrop"
            app:strokeColor="#FFFFFF"
            app:strokeWidth="4dp"
            app:shapeAppearanceOverlay="@style/CircleImage" />
    </RelativeLayout>
</com.google.android.material.card.MaterialCardView>
